generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TEXT
  NUMBER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(STUDENT)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())

  courses      Course[]      @relation("TeacherCourses")
  enrollments  Enrollment[]
  quizAttempts QuizAttempt[]
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  teacherId   String
  teacher     User     @relation("TeacherCourses", fields: [teacherId], references: [id], onDelete: Cascade)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  modules     Module[]
  enrollments Enrollment[]

  @@index([teacherId])
}

model Module {
  id       String  @id @default(cuid())
  courseId String
  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  order    Int     @default(0)

  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id          String @id @default(cuid())
  moduleId    String
  module      Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  content     String @default("")
  order       Int    @default(0)
  durationMin Int    @default(5)

  progress LessonProgress[]
  quiz     Quiz?

  @@index([moduleId])
}

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  progress LessonProgress[]

  @@unique([studentId, courseId])
  @@index([courseId])
}

model LessonProgress {
  id           String   @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt  DateTime @default(now())

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
}

model Quiz {
  id       String @id @default(cuid())
  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title    String @default("")

  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id     String       @id @default(cuid())
  quizId String
  quiz   Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type   QuestionType
  prompt String
  order  Int          @default(0)
  points Int          @default(1)

  // Correct-answer config, by type. Choice types use `options.isCorrect`;
  // TEXT/NUMBER use the scalar fields below.
  options       QuestionOption[]
  correctText   String?
  correctNumber Float?

  answers AttemptAnswer[]

  @@index([quizId])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)

  @@index([questionId])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId      String
  student        User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score          Int // percent 0-100
  pointsEarned   Int
  pointsPossible Int
  submittedAt    DateTime @default(now())

  answers AttemptAnswer[]

  @@index([quizId])
  @@index([studentId])
}

model AttemptAnswer {
  id                String   @id @default(cuid())
  attemptId         String
  attempt           QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId        String
  question          Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptionIds String[] // choice types
  textValue         String?
  numberValue       Float?
  isCorrect         Boolean

  @@index([attemptId])
  @@index([questionId])
}
